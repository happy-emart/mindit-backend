# Supabase Database (Transaction Pooler - Port 6543)
# Format: postgresql+asyncpg://[user]:[password]@[host]:6543/[db_name]?pgbouncer=true
DATABASE_URL=postgresql+asyncpg://postgres.your-ref:your-pass@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true

# Supabase Auth
# Found in Supabase Dashboard -> Project Settings -> API -> JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Google Gemini API
GOOGLE_API_KEY=your-gemini-api-key

# Optional: Port (Koyeb sets this auto, but for local dev)
PORT=8000
